    },
    {
      "page": 4,
      "source": "artwork/clean/page-04-clean.png",
      "output": "artwork/composited/page-04-final.png",
      "text": "妈妈说：“我们看看。”",
      "box": { "x": 750, "y": 105, "width": 690, "height": 220, "align": "right" }
    },
    {
      "page": 5,
      "source": "artwork/clean/page-05-clean.png",
      "output": "artwork/composited/page-05-final.png",
      "text": "原来，是小外套的影子。",
      "box": { "x": 105, "y": 105, "width": 900, "height": 220, "align": "left" }
    },
    {
      "page": 6,
      "source": "artwork/clean/page-06-clean.png",
      "output": "artwork/composited/page-06-final.png",
      "text": "小葫芦把小兔抱近一点。",
      "box": { "x": 650, "y": 105, "width": 780, "height": 230, "align": "right" }
    },
    {
      "page": 7,
      "source": "artwork/clean/page-07-clean.png",
      "output": "artwork/composited/page-07-final.png",
      "text": "小葫芦说：“门留一点点。”",
      "box": { "x": 105, "y": 105, "width": 910, "height": 230, "align": "left" }
    },
    {
      "page": 8,
      "source": "artwork/clean/page-08-clean.png",
      "output": "artwork/composited/page-08-final.png",
      "text": "小葫芦轻轻叫：“妈妈？”\n“我在呢。”",
      "box": { "x": 120, "y": 88, "width": 1296, "height": 260, "align": "center" }
    },
    {
      "page": 9,
      "source": "artwork/clean/page-09-clean.png",
      "output": "artwork/composited/page-09-final.png",
      "text": "小葫芦说：“等一等。”\n他数了三颗星星。",
      "box": { "x": 700, "y": 100, "width": 720, "height": 290, "align": "right" }
    },
    {
      "page": 10,
      "source": "artwork/clean/page-10-clean.png",
      "output": "artwork/composited/page-10-final.png",
      "text": "小葫芦说：“我先躺一会儿。”\n妈妈说：“好，我在这里。”",
      "box": { "x": 100, "y": 100, "width": 970, "height": 310, "align": "left" }
    }
